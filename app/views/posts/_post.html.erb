<% feed_cfg = post.respond_to?(:feed_config) ? post.feed_config : nil %>
<% description = format_post_description(post) %>
<div class="rss-post group relative px-4 py-4 border-b border-gray-200 dark:border-gray-800 hover:bg-gray-50 dark:hover:bg-gray-800/40 <%= "is-read" if post.read? %> <%= "is-starred" if post.starred? %>"
     data-controller="post-read star"
     data-post-read-url-value="<%= post_read_path(post.id) %>"
     data-post-read-read-value="<%= post.read? %>"
     data-star-url-value="<%= post_star_path(post.id) %>"
     data-star-starred-value="<%= post.starred? %>">

  <%# Title %>
  <h3 class="font-bold text-black dark:text-gray-100 text-lg leading-snug pr-24">
    <a href="<%= post.url %>" target="_blank" rel="noopener" data-action="post-read#markRead" data-post-open class="hover:underline"><%= post.title %></a>
  </h3>

  <%# Excerpt %>
  <% if description.present? %>
    <p class="text-gray-600 dark:text-gray-400 mt-1 line-clamp-2"><%= description %></p>
  <% end %>

  <%# Meta row %>
  <div class="flex items-center gap-2 mt-2 text-sm text-gray-500 dark:text-gray-500">
    <% if feed_cfg %>
      <span class="shrink-0 w-2.5 h-2.5 rounded-sm" style="background-color: <%= legible_feed_color(feed_cfg.color) %>"></span>
      <%= link_to feed_cfg.name, feed_posts_path(feed_cfg.encoded_url), class: "hover:text-black dark:hover:text-gray-300" %>
      <span aria-hidden="true">&middot;</span>
    <% end %>
    <time title="<%= Time.at(post.published_at).iso8601 %>"><%= post_date(post.published_at) %></time>
  </div>

  <%# Hover actions: mark read, star, open original %>
  <div class="post-actions absolute right-3 top-3 flex items-center gap-1">
    <button type="button" data-post-read-target="toggle" data-action="post-read#toggle"
            title="Toggle read" aria-label="Toggle read"
            class="rounded-md p-1.5 text-gray-500 hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer">
      <%= icon "circle", class: "read-undone size-4" %>
      <%= icon "circle-check", class: "read-done size-4" %>
    </button>
    <button type="button" data-action="star#toggle"
            title="Star" aria-label="Star"
            class="star-btn rounded-md p-1.5 text-gray-500 hover:bg-gray-200 dark:hover:bg-gray-700 cursor-pointer">
      <%= icon "star", class: "star-icon size-4" %>
    </button>
    <a href="<%= post.url %>" target="_blank" rel="noopener" data-action="post-read#markRead"
       title="Open original" aria-label="Open original"
       class="rounded-md p-1.5 text-gray-500 hover:bg-gray-200 dark:hover:bg-gray-700">
      <%= icon "external-link", class: "size-4" %>
    </a>
  </div>
</div>
