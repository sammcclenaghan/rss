<% feed_cfg = post.respond_to?(:feed_config) ? post.feed_config : nil %>
<% description = format_post_description(post) %>
<div class="rss-post group relative px-4 py-4 border-b border-border hover:bg-muted/50 <%= "is-read" if post.read? %> <%= "is-starred" if post.starred? %>"
     data-controller="post-read star"
     data-post-read-url-value="<%= post_reading_path(post) %>"
     data-post-read-read-value="<%= post.read? %>"
     data-post-read-feed-id-value="<%= post.feed_id %>"
     data-star-url-value="<%= post_star_path(post.id) %>"
     data-star-starred-value="<%= post.starred? %>">

  <%# Title — full emphasis when unread, muted once read (driven by .is-read) %>
  <h3 class="post-title text-foreground font-medium text-[15px] leading-snug pr-24 line-clamp-2">
    <a href="<%= post_link(post) %>" target="_blank" rel="noopener" data-action="post-read#markRead" data-post-open class="hover:underline"><%= post.title %></a>
  </h3>

  <%# Excerpt %>
  <% if description.present? %>
    <p class="text-muted-foreground mt-1 line-clamp-2"><%= description %></p>
  <% end %>

  <%# Meta row %>
  <div class="flex items-center gap-2 mt-2 text-xs text-muted-foreground">
    <% if feed_cfg %>
      <span class="shrink-0 w-2.5 h-2.5 rounded-sm" style="background-color: <%= legible_feed_color(feed_cfg.color) %>"></span>
      <span class="min-w-0 truncate font-medium"><%= feed_cfg.name %></span>
      <span aria-hidden="true" class="shrink-0">&middot;</span>
    <% end %>
    <time class="shrink-0" title="<%= Time.at(post.published_at).iso8601 %>"><%= post_date(post.published_at) %></time>
  </div>

  <%# Hover actions: mark read, star, open original %>
  <div class="post-actions absolute right-3 top-3 flex items-center gap-1">
    <button type="button" data-post-read-target="toggle" data-action="post-read#toggle"
            title="Toggle read" aria-label="Toggle read"
            class="read-btn inline-flex items-center justify-center rounded-md p-1.5 text-muted-foreground bg-muted hover:bg-accent hover:text-accent-foreground cursor-pointer">
      <%= icon "circle", class: "read-undone size-4", stroke_width: 2.5 %>
      <%= icon "circle-check", class: "read-done size-4", stroke_width: 2.5 %>
    </button>
    <button type="button" data-action="star#toggle"
            title="Star" aria-label="Star"
            class="star-btn inline-flex items-center justify-center rounded-md p-1.5 text-muted-foreground bg-muted hover:bg-accent hover:text-accent-foreground cursor-pointer">
      <%= icon "star", class: "star-icon size-4", stroke_width: 2.5 %>
    </button>
    <a href="<%= post_link(post) %>" target="_blank" rel="noopener" data-action="post-read#markRead"
       title="Open original" aria-label="Open original"
       class="inline-flex items-center justify-center rounded-md p-1.5 text-muted-foreground bg-muted hover:bg-accent hover:text-accent-foreground">
      <%= icon "external-link", class: "size-4", stroke_width: 2.5 %>
    </a>
  </div>
</div>
