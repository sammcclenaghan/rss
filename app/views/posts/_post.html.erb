<% feed_cfg = post.respond_to?(:feed_config) ? post.feed_config : nil %>
<% description = format_post_description(post) %>
<div class="rss-post p-4 block border border-transparent hover:border-gray-200 hover:bg-gray-100 dark:hover:border-gray-700 dark:hover:bg-gray-800 rounded hover:relative hover:z-20 -my-px <%= "is-read" if post.read? %>"
     data-controller="post-read"
     data-post-read-url-value="<%= post_read_path(post.id) %>"
     data-post-read-read-value="<%= post.read? %>">

  <%# Meta row %>
  <div class="flex text-sm text-gray-600 dark:text-gray-400 items-center flex-wrap">
    <% if feed_cfg %>
      <%= link_to feed_cfg.name,
          feed_posts_path(feed_cfg.encoded_url),
          style: "color: #{legible_feed_color(feed_cfg.color)}",
          class: "font-bold text-xs block" %>
      <div class="px-2">&bull;</div>
    <% end %>
    <div class="italic" title="<%= Time.at(post.published_at).iso8601 %>">
      About <%= relative_published_time(post.published_at) %> ago
    </div>
    <% if feed_cfg&.tags&.any? %>
      <div class="px-2 hidden md:block">&bull;</div>
      <div class="flex gap-2 basis-full md:basis-auto">
        <% feed_cfg.tags.each do |tag| %>
          <%= link_to tag, tag_posts_path(tag.delete("#")), class: "inline-block" %>
        <% end %>
      </div>
    <% end %>
    <button type="button"
            data-post-read-target="toggle"
            data-action="post-read#toggle"
            class="ml-auto text-xs hover:text-black dark:hover:text-gray-300 cursor-pointer">
      <%= post.read? ? "Read" : "Mark read" %>
    </button>
  </div>

  <%# Body — List mode (thumbnail side by side) %>
  <div class="format-list-only flex items-center gap-5">
    <% if post.thumbnail.present? %>
      <div class="w-32 shrink-0">
        <a href="<%= post.url %>" target="_blank" data-action="post-read#markRead" class="block overflow-hidden rounded my-2 border border-gray-200 dark:border-black">
          <img src="/storage/<%= post.thumbnail %>"
               loading="lazy"
               class="w-full object-cover saturate-50 h-16"
               alt="<%= post.title %>">
        </a>
      </div>
    <% end %>
    <div class="flex-1 min-w-0">
      <h3 class="font-bold text-black dark:text-gray-300">
        <a href="<%= post.url %>" target="_blank" data-action="post-read#markRead" class="hover:underline"><%= post.title %></a>
      </h3>
      <p class="text-gray-600 dark:text-gray-400"><%= description %></p>
    </div>
  </div>

  <%# Body — Card mode (thumbnail above) %>
  <div class="format-card-only">
    <% if post.thumbnail.present? %>
      <a href="<%= post.url %>" target="_blank" data-action="post-read#markRead" class="block overflow-hidden rounded my-2 border border-gray-200 dark:border-black">
        <img src="/storage/<%= post.thumbnail %>"
             loading="lazy"
             class="w-full object-cover saturate-50 h-32 md:h-48 lg:h-64"
             alt="<%= post.title %>">
      </a>
    <% end %>
    <h3 class="font-bold text-black dark:text-gray-300 text-lg">
      <a href="<%= post.url %>" target="_blank" data-action="post-read#markRead" class="hover:underline"><%= post.title %></a>
    </h3>
    <p class="text-gray-600 dark:text-gray-400"><%= description %></p>
  </div>

  <%# Body — Compact mode (inline, clipped to a single line). The wrapper paints
      the ellipsis, so colour it to match the description. %>
  <div class="format-compact-only whitespace-nowrap overflow-hidden text-ellipsis text-gray-600 dark:text-gray-400">
    <h3 class="font-bold text-black dark:text-gray-300 inline">
      <a href="<%= post.url %>" target="_blank" data-action="post-read#markRead" class="hover:underline"><%= post.title %></a>
    </h3>
    <p class="text-gray-600 dark:text-gray-400 inline ml-2 text-sm"><%= description %></p>
  </div>
</div>
