<div class="md:flex h-full min-h-0"
     data-controller="mobile-sidebar keyboard">

  <%# Sidebar — only rendered on full-page requests; turbo-frame requests
      (search, pagination) update just the #posts frame and skip sidebar data. %>
  <% if @sidebar_feeds %>
  <div class="md:w-72 xl:w-80 shrink-0 md:border-r border-gray-200 dark:border-black bg-gray-50 dark:bg-gray-900 md:overflow-auto px-4 md:px-3 py-3 md:h-full">

    <%# Brand + mobile toggle %>
    <div class="flex items-center justify-between mb-4 px-2">
      <%= link_to root_path, class: "flex items-center gap-2 text-black dark:text-gray-100" do %>
        <%= icon "rss", class: "size-6 text-blue-600 dark:text-blue-500" %>
        <span class="font-bold text-lg"><%= content_for(:title) || "Rss" %></span>
      <% end %>
      <button data-action="click->mobile-sidebar#toggle"
              class="md:hidden rounded p-1.5 text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800">
        <%= icon "chevron-right", class: "size-[18px] transition-transform", data: { mobile_sidebar_target: "icon" } %>
      </button>
    </div>

    <%# Sidebar content %>
    <div data-mobile-sidebar-target="content" class="hidden md:block">

      <%# Search %>
      <%= form_tag search_scope_path, method: :get, data: { controller: "search", action: "input->search#submit submit->search#cancel", turbo_frame: "posts" }, class: "relative mb-4" do %>
        <%= icon "search", class: "size-4 absolute left-2.5 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none" %>
        <%= text_field_tag :query, @query, placeholder: "Search",
              class: "w-full rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-black dark:text-gray-200 placeholder:text-gray-400 pl-8 pr-9 py-1.5 text-sm",
              data: { search_target: "input" } %>
        <kbd class="absolute right-2 top-1/2 -translate-y-1/2 rounded border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-900 px-1.5 text-xs text-gray-500 font-mono">/</kbd>
        <%= hidden_field_tag :unread, "1" if @unread_only %>
        <%= hidden_field_tag :starred, "1" if @starred_only %>
      <% end %>

      <%# Top nav — global, root-scoped views. %>
      <% global_scope = @tag.blank? && @selected_feed.blank? %>
      <% home_active = global_scope && !@unread_only && !@starred_only %>
      <nav class="space-y-0.5 mb-5">
        <%= link_to root_path(unread: 1), class: sidebar_nav_class(global_scope && @unread_only) do %>
          <%= icon "mail", class: "size-4" %>
          <span>Unread</span>
          <% if @unread_total.to_i > 0 %><span class="ml-auto text-xs text-gray-500 dark:text-gray-500 tabular-nums"><%= @unread_total %></span><% end %>
        <% end %>

        <%= link_to root_path(starred: 1), class: sidebar_nav_class(global_scope && @starred_only) do %>
          <%= icon "star", class: "size-4" %>
          <span>Starred</span>
          <% if @starred_count.to_i > 0 %><span class="ml-auto text-xs text-gray-500 dark:text-gray-500 tabular-nums"><%= @starred_count %></span><% end %>
        <% end %>

        <%= link_to root_path, class: sidebar_nav_class(home_active) do %>
          <%= icon "list", class: "size-4" %>
          <span>All</span>
          <% if @unread_total.to_i > 0 %><span class="ml-auto text-xs text-gray-500 dark:text-gray-500 tabular-nums"><%= @unread_total %></span><% end %>
        <% end %>
      </nav>

      <%# Feeds — grouped into collapsible folders by tag. %>
      <h2 class="px-2 mb-1 text-xs font-semibold uppercase tracking-wide text-gray-400 dark:text-gray-500">Feeds</h2>
      <% grouped_feeds(@sidebar_feeds, @sidebar_unread_counts).each do |group| %>
        <% folder_active = group[:tag].present? && @tag == group[:tag] %>
        <div class="mb-1" data-controller="folder" data-folder-key-value="<%= group[:name] %>">
          <div class="group flex items-center rounded-md px-2 py-1 <%= "bg-gray-100 dark:bg-gray-800/60" if folder_active %>">
            <button type="button" data-action="folder#toggle"
                    class="shrink-0 mr-1 text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 cursor-pointer">
              <%= icon "chevron-down", class: "size-3.5 transition-transform", data: { folder_target: "chevron" } %>
            </button>
            <% if group[:tag] %>
              <%= link_to group[:name], tag_posts_path(group[:tag]),
                    class: "flex-1 min-w-0 truncate text-sm font-semibold text-gray-700 dark:text-gray-300 hover:text-black dark:hover:text-gray-100" %>
            <% else %>
              <button type="button" data-action="folder#toggle"
                      class="flex-1 min-w-0 truncate text-left text-sm font-semibold text-gray-700 dark:text-gray-300 cursor-pointer"><%= group[:name] %></button>
            <% end %>
            <% if group[:unread] > 0 %>
              <span class="ml-2 shrink-0 text-xs text-gray-500 dark:text-gray-500 tabular-nums"><%= group[:unread] %></span>
            <% end %>
          </div>
          <div data-folder-target="content">
            <% group[:feeds].each do |feed| %>
              <%= render "feeds/feed", feed: feed, unread_counts: @sidebar_unread_counts %>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
  <% end %>

  <%# Main content %>
  <div class="md:flex-1 min-w-0 flex flex-col md:h-full md:overflow-hidden">

    <%# Header: current view title + mark all as read %>
    <div class="flex items-center justify-between gap-4 px-6 md:px-10 py-3 border-b border-gray-200 dark:border-gray-800">
      <h1 class="text-xl font-bold text-black dark:text-gray-100 truncate"><%= current_view_title %></h1>
      <%= button_to read_all_posts_path,
            params: { tag: @tag, feed: @selected_feed, query: @query },
            data: { keyboard_target: "markAll" },
            class: "shrink-0 inline-flex items-center gap-1.5 rounded-md border border-gray-300 dark:border-gray-700 px-3 py-1.5 text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-800 cursor-pointer" do %>
        <%= icon "check-check", class: "size-4" %>
        Mark all as read
      <% end %>
    </div>

    <div class="md:flex-1 md:overflow-auto px-6 md:px-10 py-4">
      <%= turbo_frame_tag "posts", class: "block" do %>

        <%# Filter tabs %>
        <div class="mb-4">
          <div class="inline-flex rounded-lg bg-gray-100 dark:bg-gray-800 p-0.5 text-sm">
            <%= link_to "All", filter_path(:all), class: content_tab_class(:all) %>
            <%= link_to "Unread", filter_path(:unread),
                  data: { keyboard_target: (@unread_only ? nil : "unreadToggle") },
                  class: content_tab_class(:unread) %>
            <%= link_to "Starred", filter_path(:starred), class: content_tab_class(:starred) %>
          </div>
          <%# Keep the unread toggle reachable from the keyboard when unread is on. %>
          <% if @unread_only %>
            <%= link_to "", filter_path(:all), data: { keyboard_target: "unreadToggle" }, class: "hidden" %>
          <% end %>
        </div>

        <%# Posts %>
        <% if @posts.empty? %>
          <p class="py-16 text-center text-gray-500 dark:text-gray-500"><%= @starred_only ? "No starred posts." : @unread_only ? "No unread posts." : "No posts yet." %></p>
        <% end %>
        <div class="border-t border-gray-200 dark:border-gray-800">
          <% @posts.each do |post| %>
            <%= render "posts/post", post: post %>
          <% end %>
        </div>

        <%# Pagination %>
        <div class="py-2 flex">
          <% if @page > 1 %>
            <%= link_to raw("&laquo; Previous Page"),
                url_for(page: @page - 1, query: @query, unread: @unread_only ? "1" : nil, starred: @starred_only ? "1" : nil),
                data: { turbo_frame: "posts" },
                class: "text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 font-bold py-2 hover:text-black" %>
          <% end %>
          <% if @posts.length == 100 %>
            <%= link_to raw("Next Page &raquo;"),
                url_for(page: @page + 1, query: @query, unread: @unread_only ? "1" : nil, starred: @starred_only ? "1" : nil),
                data: { turbo_frame: "posts" },
                class: "ml-auto text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 font-bold py-2 hover:text-black" %>
          <% end %>
        </div>

      <% end %>
    </div>
  </div>

  <%# Keyboard shortcuts help %>
  <div data-keyboard-target="help" data-action="click->keyboard#closeHelp"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4">
    <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded p-6 max-w-sm w-full text-gray-700 dark:text-gray-300">
      <h2 class="font-bold mb-4 text-black dark:text-gray-200">Keyboard shortcuts</h2>
      <dl class="space-y-2 text-sm">
        <% [
             [ "j / k", "Next / previous post" ],
             [ "o / Enter", "Open original article (marks read)" ],
             [ "m", "Toggle read / unread" ],
             [ "u", "Toggle unread-only filter" ],
             [ "Shift + A", "Mark all read" ],
             [ "g g / G", "First / last post" ],
             [ "/", "Focus search" ],
             [ "?", "Toggle this help" ],
             [ "Esc", "Close help / leave search" ]
           ].each do |keys, label| %>
          <div class="flex items-center justify-between gap-4">
            <span><%= label %></span>
            <kbd class="shrink-0 px-1.5 py-0.5 rounded border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-900 font-mono text-xs"><%= keys %></kbd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>
</div>
