<div class="md:flex h-full min-h-0"
     data-controller="mobile-sidebar format-selector keyboard"
     data-format-selector-storage-key-value="post-format">

  <%# Sidebar %>
  <div class="md:w-1/3 xl:w-1/4 md:flex md:justify-end md:border-r border-gray-200 dark:border-black px-6 bg-gray-50 dark:bg-gray-800 md:px-12 md:overflow-auto py-3">

    <%# Mobile toggle %>
    <div class="md:hidden mb-2">
      <button data-action="click->mobile-sidebar#toggle"
              class="border w-full rounded py-1 px-3 hover:bg-gray-100 dark:hover:bg-gray-700 border-2 border-gray-200 text-gray-600 dark:text-gray-400 dark:border-gray-600 gap-3 font-bold flex items-center">
        <svg data-mobile-sidebar-target="icon"
             class="transition-transform"
             xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
          <path d="m12.14 8.753-5.482 4.796c-.646.566-1.658.106-1.658-.753V3.204a1 1 0 0 1 1.659-.753l5.48 4.796a1 1 0 0 1 0 1.506z"/>
        </svg>
        Toggle filters &amp; options
      </button>
    </div>

    <%# Sidebar content %>
    <div data-mobile-sidebar-target="content"
         class="md:max-w-xs w-full hidden md:block">

      <%# Back to home %>
      <% if @query.present? || @tag.present? || @selected_feed.present? || @page > 1 %>
        <div class="mb-8">
          <%= link_to raw("&laquo; Back to home"), root_path, class: "font-bold text-black dark:text-gray-400" %>
        </div>
      <% end %>

      <%# Search %>
      <div class="mb-8">
        <h2 class="font-bold mb-2 dark:text-gray-400">Search</h2>
        <%= form_tag search_scope_path, method: :get, data: { controller: "search", action: "input->search#submit submit->search#cancel", turbo_frame: "posts" }, class: "flex gap-2" do %>
          <%= text_field_tag :query, @query, placeholder: "Post name or description",
                class: "border border-gray-300 dark:border-black rounded px-2 py-1 w-full bg-white dark:bg-gray-900 text-black dark:text-gray-200 placeholder:text-gray-400",
                data: { search_target: "input" } %>
          <%= hidden_field_tag :unread, "1" if @unread_only %>
        <% end %>
      </div>

      <%# Tags %>
      <% tags = @display_feeds.flat_map(&:tags).uniq.sort %>
      <% if tags.any? %>
        <div class="mb-8">
          <h2 class="font-bold mb-2 dark:text-gray-400">Tags</h2>
          <% tags.each do |tag| %>
            <%= link_to tag, tag_posts_path(tag.delete("#")), class: "inline-block mr-3 font-bold text-gray-600 dark:text-gray-500" %>
          <% end %>
        </div>
      <% end %>

      <%# Feeds %>
      <div class="mb-8">
        <h2 class="font-bold dark:text-gray-400">Feeds</h2>
        <% @display_feeds.each do |feed| %>
          <%= render "feeds/feed", feed: feed %>
          <hr class="last:hidden border-gray-200 dark:border-gray-700">
        <% end %>
      </div>

    </div>
  </div>

  <%# Main content %>
  <div class="md:w-2/3 xl:w-3/4 px-6 md:px-12 md:overflow-auto md:h-full py-2">
    <%= turbo_frame_tag "posts", data: { format_selector_target: "container" }, class: "format-card max-w-lg" do %>

      <%# Title bar %>
      <div class="flex items-center justify-between mb-2">
        <h2 class="font-bold text-black dark:text-gray-400">
          <%= link_to "Posts", root_path %>
          <% if @tag.present? %>
            / #<%= @tag %>
          <% end %>
          <% if @selected_feed.present? && @display_feeds.length == 1 %>
            / <span style="color: <%= @display_feeds.first.color %>"><%= @display_feeds.first.name %></span>
          <% end %>
          <% if @query.present? %>
            / ?= <%= @query %>
          <% end %>
        </h2>

        <%# Format selector %>
        <div class="border rounded border-gray-300 dark:border-gray-600 divide-x divide-gray-300 dark:divide-gray-600 text-gray-600 dark:text-gray-400 flex">
          <button title="Card View" type="button"
                  data-format-selector-target="button"
                  data-action="click->format-selector#select" data-format="card"
                  class="format-btn px-2 py-1 bg-gray-100 text-gray-900 dark:bg-gray-800 dark:text-gray-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M14.5 3a.5.5 0 0 1 .5.5v9a.5.5 0 0 1-.5.5h-13a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h13zm-13-1A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h13a1.5 1.5 0 0 0 1.5-1.5v-9A1.5 1.5 0 0 0 14.5 2h-13z"/>
              <path d="M3 8.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zm0 2a.5.5 0 0 1 .5-.5h6a.5.5 0 0 1 0 1h-6a.5.5 0 0 1-.5-.5zm0-5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-9a.5.5 0 0 1-.5-.5v-1z"/>
            </svg>
          </button>
          <button title="List View" type="button"
                  data-format-selector-target="button"
                  data-action="click->format-selector#select" data-format="list"
                  class="format-btn px-2 py-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="M3 4.5h10a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2zm0 1a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1H3zM1 2a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 0 1h-13A.5.5 0 0 1 1 2zm0 12a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 0 1h-13A.5.5 0 0 1 1 14z"/>
            </svg>
          </button>
          <button title="Compact View" type="button"
                  data-format-selector-target="button"
                  data-action="click->format-selector#select" data-format="compact"
                  class="format-btn px-2 py-1">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path fill-rule="evenodd" d="M2 2.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5V3a.5.5 0 0 0-.5-.5H2zM3 3H2v1h1V3z"/>
              <path d="M5 3.5a.5.5 0 0 1 .5-.5h9a.5.5 0 0 1 0 1h-9a.5.5 0 0 1-.5-.5zM5.5 7a.5.5 0 0 0 0 1h9a.5.5 0 0 0 0-1h-9zm0 4a.5.5 0 0 0 0 1h9a.5.5 0 0 0 0-1h-9z"/>
              <path fill-rule="evenodd" d="M1.5 7a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5H2a.5.5 0 0 1-.5-.5V7zM2 7h1v1H2V7zm0 3.5a.5.5 0 0 0-.5.5v1a.5.5 0 0 0 .5.5h1a.5.5 0 0 0 .5-.5v-1a.5.5 0 0 0-.5-.5H2zm1 .5H2v1h1v-1z"/>
            </svg>
          </button>
        </div>
      </div>

      <%# Read controls %>
      <div class="flex items-center gap-4 mb-2 text-sm text-gray-600 dark:text-gray-500">
        <% if @unread_only %>
          <%= link_to "Show all", unread_filter_path(enable: false),
                data: { keyboard_target: "unreadToggle", turbo_frame: "posts" },
                class: "font-bold hover:text-black dark:hover:text-gray-300" %>
        <% else %>
          <%= link_to "Unread only", unread_filter_path(enable: true),
                data: { keyboard_target: "unreadToggle", turbo_frame: "posts" },
                class: "font-bold hover:text-black dark:hover:text-gray-300" %>
        <% end %>
        <%= button_to "Mark all read", read_all_posts_path,
              params: { tag: @tag, feed: @selected_feed, query: @query },
              data: { keyboard_target: "markAll" },
              class: "font-bold hover:text-black dark:hover:text-gray-300 cursor-pointer" %>
      </div>

      <%# Posts %>
      <div class="-mx-4">
        <% if @posts.empty? %>
          <p class="px-4 py-8 text-gray-600 dark:text-gray-500"><%= @unread_only ? "No unread posts." : "No posts yet." %></p>
        <% end %>
        <% @posts.each do |post| %>
          <%= render "posts/post", post: post %>
          <div class="px-4">
            <hr class="border-gray-200 dark:border-gray-700">
          </div>
        <% end %>
      </div>

      <%# Pagination %>
      <div class="py-2 flex">
        <% if @page > 1 %>
          <%= link_to raw("&laquo; Previous Page"),
              url_for(page: @page - 1, query: @query, unread: @unread_only ? "1" : nil),
              data: { turbo_frame: "posts" },
              class: "text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 font-bold py-2 hover:text-black" %>
        <% end %>
        <% if @posts.length == 100 %>
          <%= link_to raw("Next Page &raquo;"),
              url_for(page: @page + 1, query: @query, unread: @unread_only ? "1" : nil),
              data: { turbo_frame: "posts" },
              class: "ml-auto text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 font-bold py-2 hover:text-black" %>
        <% end %>
      </div>

    <% end %>
  </div>

  <%# Keyboard shortcuts help %>
  <div data-keyboard-target="help" data-action="click->keyboard#closeHelp"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50 px-4">
    <div class="bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded p-6 max-w-sm w-full text-gray-700 dark:text-gray-300">
      <h2 class="font-bold mb-4 text-black dark:text-gray-200">Keyboard shortcuts</h2>
      <dl class="space-y-2 text-sm">
        <% [
             [ "j / k", "Next / previous post" ],
             [ "o / Enter", "Open selected post (marks read)" ],
             [ "m", "Toggle read / unread" ],
             [ "u", "Toggle unread-only filter" ],
             [ "Shift + A", "Mark all read" ],
             [ "g g / G", "First / last post" ],
             [ "/", "Focus search" ],
             [ "?", "Toggle this help" ],
             [ "Esc", "Close help / leave search" ]
           ].each do |keys, label| %>
          <div class="flex items-center justify-between gap-4">
            <span><%= label %></span>
            <kbd class="shrink-0 px-1.5 py-0.5 rounded border border-gray-300 dark:border-gray-600 bg-gray-100 dark:bg-gray-900 font-mono text-xs"><%= keys %></kbd>
          </div>
        <% end %>
      </dl>
    </div>
  </div>
</div>
