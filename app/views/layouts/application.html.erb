<!DOCTYPE html>
<html class="h-full dark:bg-gray-900">
  <head>
    <title><%= content_for(:title) || "Rss" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Rss">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application' %>
    <%= vite_stylesheet_tag 'application.css' %>

    <%# Apply saved format preference before first paint so the browser never
        renders the card layout when card is not the user's preferred format. %>
    <script>
    (function(){
      var f=localStorage.getItem('post-format');
      if(!f||f==='card')return;
      var W={card:'max-w-lg',list:'max-w-2xl',compact:'w-full'},
          M={card:'format-card',list:'format-list',compact:'format-compact'};
      if(!M[f])return;
      function apply(){
        var el=document.querySelector('[data-format-selector-target="container"]');
        if(!el)return false;
        el.classList.remove('format-card','format-list','format-compact',
                            'max-w-lg','max-w-2xl','w-full');
        el.classList.add(M[f],W[f]);
        return true;
      }
      if(apply())return;
      var obs=new MutationObserver(function(){if(apply())obs.disconnect()});
      obs.observe(document.documentElement,{childList:true,subtree:true});
      setTimeout(function(){obs.disconnect()},1e3);
    })();
    </script>

  </head>

  <body class="h-full text-gray-900 dark:text-gray-300">
    <%= yield %>
  </body>
</html>
