<% feed_cfg = feed %>
<% counts = local_assigns[:unread_counts] || {} %>
<% unread_count = counts.fetch(feed_cfg.feed.id, 0).to_i %>
<% active = defined?(@selected_feed) && @selected_feed.present? && @selected_feed == feed_cfg.url %>
<div class="py-px" data-controller="feed-poll"
     data-feed-poll-url-value="<%= feed_cfg.url %>"
     data-feed-poll-reloading-value="<%= feed_cfg.reloading? %>">
  <%= link_to feed_posts_path(feed_cfg.encoded_url),
        class: "group flex items-center gap-2 rounded-md pl-7 pr-2 py-1 text-sm #{active ? 'bg-gray-200 text-black dark:bg-gray-800 dark:text-gray-100' : 'text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-800 hover:text-black dark:hover:text-gray-200'}" do %>
    <span class="shrink-0 w-2 h-2 rounded-sm" style="background-color: <%= legible_feed_color(feed_cfg.color) %>"></span>
    <span class="flex-1 min-w-0 truncate"><%= feed_cfg.name %></span>
    <% if feed_cfg.hidden %>
      <span title="Posts hidden by default" class="shrink-0 flex"><%= icon "eye-off", class: "size-3.5 text-gray-400" %></span>
    <% end %>
    <% if unread_count > 0 %>
      <span class="shrink-0 text-xs text-gray-500 dark:text-gray-500 tabular-nums"><%= unread_count %></span>
    <% end %>
  <% end %>
  <div data-feed-poll-target="status" class="hidden flex items-center gap-2 text-gray-600 text-xs pl-7 py-1">
    <%= icon "refresh-cw", class: "size-3.5 animate-spin" %>
    <span>Reloading…</span>
  </div>
</div>
