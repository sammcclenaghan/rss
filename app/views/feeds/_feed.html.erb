<% feed_cfg = feed %>
<% counts = local_assigns[:unread_counts] || {} %>
<% unread_count = counts.fetch(feed_cfg.feed.id, 0).to_i %>
<% active = defined?(@selected_feed) && @selected_feed.present? && @selected_feed == feed_cfg.url %>
<div class="py-px" data-controller="feed-poll"
     data-feed-poll-url-value="<%= feed_cfg.url %>"
     data-feed-poll-reloading-value="<%= feed_cfg.reloading? %>">
  <%= link_to feed_posts_path(feed_cfg.encoded_url),
        class: "group flex items-center gap-2 rounded-md pl-7 pr-2 py-1 text-sm #{active ? 'bg-sidebar-accent text-sidebar-accent-foreground' : 'text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground'}" do %>
    <span class="shrink-0 w-2 h-2 rounded-sm" style="background-color: <%= legible_feed_color(feed_cfg.color) %>"></span>
    <span class="flex-1 min-w-0 truncate"><%= feed_cfg.name %></span>
    <% if feed_cfg.hidden %>
      <span title="Posts hidden by default" class="shrink-0 flex"><%= icon "eye-off", class: "size-3.5 text-muted-foreground" %></span>
    <% end %>
    <span data-counts-target="feed" data-feed-id="<%= feed_cfg.feed.id %>"
          class="shrink-0 text-xs text-muted-foreground tabular-nums <%= "hidden" if unread_count == 0 %>"><%= unread_count %></span>
  <% end %>
  <div data-feed-poll-target="status" class="hidden flex items-center gap-2 text-muted-foreground text-xs pl-7 py-1">
    <%= icon "refresh-cw", class: "size-3.5 animate-spin" %>
    <span>Reloading…</span>
  </div>
</div>
