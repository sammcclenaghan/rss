# Copy to .env (gitignored) and fill in, then `docker compose up -d --build`.

# Required: decrypts config/credentials.yml.enc.
# Value is the contents of config/master.key.
RAILS_MASTER_KEY=

# Optional: HTTP Basic auth for the background-jobs dashboard at /jobs.
# Leave blank to keep it locked (the app fails closed and returns 401).
MISSION_CONTROL_JOBS_HTTP_BASIC_AUTH_USER=
MISSION_CONTROL_JOBS_HTTP_BASIC_AUTH_PASSWORD=
